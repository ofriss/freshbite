<?xml version="1.0"?>
<configuration>
	<!--Deny access to this folder-->
	<system.web>
		<authorization>
			<deny users="*"/>
		</authorization>
	</system.web>
	<system.webServer>
		<handlers>
			<clear/>
		</handlers>
		<staticContent>
			<clear/>
		</staticContent>
	</system.webServer>
</configuration>